{
  "printWidth": 140,
  "singleQuote": false,
  "trailingComma": "all",
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "proseWrap": "always",
  "plugins": ["@prettier/plugin-xml"],
  "overrides": [
    {
      "files": ["*.xml"],
      "options": {
        "xmlWhitespaceSensitivity": "ignore"
      }
    }
  ]
}
